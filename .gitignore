# =========================================
# Portfolio-ready .gitignore for Instacart Analytics
# Tracks only scripts, docs, and README
# Ignores all raw/processed data, database files, Tableau extracts, IDE temp files
# =========================================

# --------------------------
# Data
# --------------------------
# Ignore large raw datasets and processed CSV exports
data/raw/
data/processed/

# --------------------------
# SQL Server / Database files
# --------------------------
*.mdf           # Main database file
*.ldf           # SQL log files
*.ndf           # Secondary database files
*.bak           # Backup files
*.trn           # Transaction logs
*.dbmdl         # Database model files
*.dbschema*
*.Publish.xml
TestResults/

# --------------------------
# Tableau
# --------------------------
*.twb
*.twbx
*.tdsx
*.tds
*.tde
*.hyper
*.tab
*.backup
*.log

# --------------------------
# Visual Studio / IDE
# --------------------------
.vs/
bin/
obj/
Debug/
Release/
*.user
*.suo
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb

# JetBrains IDE
.idea/
*.iml
*.ipr
*.iws

# --------------------------
# Temporary / OS files
# --------------------------
*.tmp
*.temp
*.swp
*.swo
.DS_Store
Thumbs.db

# --------------------------
# Node / Python (optional)
# --------------------------
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
*.env
.env

# --------------------------
# Keep only tracked folders for portfolio
# --------------------------
# Scripts, docs, diagrams, README, and structure file
!sql/
!docs/
!full_script/
!README.md
!structure.txt
